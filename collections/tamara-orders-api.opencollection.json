{
  "opencollection": "1.0.0",
  "info": {
    "name": "Tamara Orders API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Orders",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Order Details by Order ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tamara.co/orders/:order_id",
            "params": [
              {
                "name": "order_id",
                "value": "",
                "type": "path"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Fetch all order details available on Tamara's side using the unique `order_id`."
        },
        {
          "info": {
            "name": "Authorise Order",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.tamara.co/orders/:order_id/authorise",
            "params": [
              {
                "name": "order_id",
                "value": "",
                "type": "path"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Transition an `approved` order to `authorised`. Should be called on receipt of the\n`order_approved` webhook event. Orders not captured within 21 days auto-capture automatically.\n"
        },
        {
          "info": {
            "name": "Cancel Order",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.tamara.co/orders/:order_id/cancel",
            "params": [
              {
                "name": "order_id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Cancel an authorised order or reduce its total amount before capture. Returns the\ncancellation id and updated amount.\n"
        },
        {
          "info": {
            "name": "Update Order Reference ID",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.tamara.co/orders/:order_id/reference-id",
            "params": [
              {
                "name": "order_id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Update the `order_reference_id` stored on Tamara's side at any point after the checkout session has been created."
        }
      ]
    }
  ],
  "bundled": true
}